D {"k":"manifest","a":"neuroplast.manifest","b":"Neuroplast LCP context","j":"LCP v2.0 entrypoint for Neuroplast-managed repository-local cognitive augmentation.","o":[{"a":"lcp-protocol","u":"https://github.com/JamesNapoletano/lcp","k":"protocol","p":"depends_on"}],"ab":[{"a":"neuroplast-default-profile","l":".lcp/profiles/neuroplast-default.yaml"},{"a":"neuroplast-loop-workflow","l":".lcp/workflows/neuroplast-loop.yaml"},{"a":"neuroplast-boundaries-rule","l":".lcp/rules/neuroplast-boundaries.yaml"},{"a":"neuroplast-execution-scaffold","l":".lcp/reasoning/neuroplast-execution-scaffold.yaml"},{"a":"neuroplast-cli-tool","l":".lcp/tools/neuroplast-cli.yaml"},{"a":"neuroplast-compatibility-knowledge","l":".lcp/knowledge/neuroplast-compatibility.yaml"},{"a":"neuroplast-learning-memory","l":".lcp/knowledge/neuroplast-learning.yaml"}],"v":["neuroplast-default"],"ac":[{"s":"lcp/quantized","t":false},{"s":"neuroplast/operational-binding","t":false}],"n":{"m":"."},"am":["neuroplast","implementation"],"c":"2026-06-30T12:00:00Z"}
