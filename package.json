{
    "name": "neuroplast",
    "version": "1.2.3",
    "description": "Repository-local cognitive augmentation toolkit implementing the Local Cognitive Protocol for local repositories.",
    "author": "James Napoletano",
    "license": "MIT",
    "type": "commonjs",
    "bin": {
        "neuroplast": "bin/neuroplast.js"
    },
    "engines": {
        "node": ">=18"
    },
    "files": [
        "bin",
        "src",
        "schemas",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "node --test",
        "init": "node ./bin/neuroplast.js init",
        "init:obsidian": "node ./bin/neuroplast.js init --with-obsidian",
        "sync": "node ./bin/neuroplast.js sync",
        "sync:dry-run": "node ./bin/neuroplast.js sync --dry-run",
        "validate": "node ./bin/neuroplast.js validate",
        "release:verify": "node ./scripts/release-verify.js"
    },
    "keywords": [
        "workflow",
        "obsidian",
        "bootstrap",
        "project-planning",
        "ai",
        "lcp",
        "local-cognitive-protocol",
        "knowledge-management"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/JamesNapoletano/neuroplast.git"
    },
    "homepage": "https://github.com/JamesNapoletano/neuroplast",
    "bugs": {
        "url": "https://github.com/JamesNapoletano/neuroplast/issues"
    },
    "publishConfig": {
        "access": "public"
    }
}
