    "url": "https://github.com/jnap9/neuroplast.git"
  },
  "homepage": "https://github.com/jnap9/neuroplast",
  "bugs": {
    "url": "https://github.com/jnap9/neuroplast/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
