{
  "name": "neuroplast",
  "version": "1.0.0",
  "description": "Bootstrap Neuroplast workflow instructions into any repository.",
  "author": "jnap9",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "neuroplast": "bin/neuroplast.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
