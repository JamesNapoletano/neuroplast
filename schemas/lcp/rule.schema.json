{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lcp.dev/schemas/rule.schema.json",
  "title": "LCP Rule",
  "allOf": [
    { "$ref": "./common-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "kind": { "const": "rule" },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "statement": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": ["statement"]
    }
  ]
}
