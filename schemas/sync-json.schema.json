{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JamesNapoletano/neuroplast/schemas/sync-json.schema.json",
  "title": "Neuroplast Sync JSON Output",
  "description": "Stable machine-readable output contract for 'neuroplast sync --json' within a major version.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "schemaVersion",
    "command",
    "packageVersion",
    "targetRoot",
    "options",
    "summary",
    "result",
    "events"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "command": { "const": "sync" },
    "packageVersion": { "type": "string", "minLength": 1 },
    "targetRoot": { "type": "string", "minLength": 1 },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["json", "dryRun", "backup", "force"],
      "properties": {
        "json": { "const": true },
        "dryRun": { "type": "boolean" },
        "backup": { "type": "boolean" },
        "force": { "type": "boolean" }
      }
    },
    "summary": { "$ref": "#/$defs/eventSummary" },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sync"],
      "properties": {
        "sync": { "$ref": "#/$defs/syncResult" }
      }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "eventSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events", "info", "errors", "created", "skipped", "updated", "preserved"],
      "properties": {
        "events": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "created": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "preserved": { "type": "integer", "minimum": 0 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "phase"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "phase": { "type": ["string", "null"] }
      }
    },
    "syncDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shouldRun", "message"],
      "properties": {
        "shouldRun": { "type": "boolean" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "managedRefresh": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["scanned", "created", "updated", "preserved", "adopted", "unchanged", "controlledPaths"],
      "properties": {
        "scanned": { "type": "integer", "minimum": 0 },
        "created": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "preserved": { "type": "integer", "minimum": 0 },
        "adopted": { "type": "integer", "minimum": 0 },
        "unchanged": { "type": "integer", "minimum": 0 },
        "controlledPaths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "migrationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "description", "updated", "scanned"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "updated": { "type": "integer", "minimum": 0 },
        "scanned": { "type": "integer", "minimum": 0 }
      }
    },
    "syncResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postInit", "dryRun", "decision", "managedRefresh", "migrations", "stateUpdated", "summary"],
      "properties": {
        "postInit": { "type": "boolean" },
        "dryRun": { "type": "boolean" },
        "decision": { "$ref": "#/$defs/syncDecision" },
        "managedRefresh": { "$ref": "#/$defs/managedRefresh" },
        "migrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/migrationResult" }
        },
        "stateUpdated": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/eventSummary" }
      }
    }
  }
}
